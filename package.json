{
  "name": "tpos-app",
  "version": "5.3.0",
  "description": "The Pile of Shame Application",
  "main": "src/main.js",
  "scripts": {
    "sync-config": "node scripts/sync-config.js",
    "prestart": "node scripts/sync-config.js",
    "start": "electron .",
    "prebuild": "node scripts/sync-config.js",
    "build": "electron-builder && powershell -Command \"Remove-Item -Recurse -Force dist\\win-unpacked -ErrorAction SilentlyContinue\"",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "better-sqlite3": "^11.0.0",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "htm": "^3.1.1",
    "lucide-react": "^0.562.0",
    "preact": "^10.28.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.tpos.app",
    "productName": "TPOS V5.3.0",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "${productName} Portable.${ext}"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**",
      "**/.node"
    ],
    "files": [
      "package.json",
      "src/**/*",
      "assets/**/*"
    ]
  }
}
